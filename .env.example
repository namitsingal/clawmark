# Clawmark configuration — set these in the environment OpenClaw's gateway runs in.
# All URL/model/path variables are required (the plugin stays inert and logs which one
# is missing otherwise).

CLAWMARK_DB_PATH=~/.openclaw/clawmark.db

# Message source: auto | lcm | transcripts (default auto).
# auto prefers Lossless Claw's DB when CLAWMARK_LCM_DB_PATH is set and valid,
# otherwise falls back to OpenClaw's native session transcripts.
CLAWMARK_SOURCE=auto
CLAWMARK_TRANSCRIPTS_DIR=~/.openclaw/agents/main/sessions
#CLAWMARK_LCM_DB_PATH=~/.openclaw/lcm.db

# OpenAI-compatible /v1/embeddings endpoint.
CLAWMARK_EMBEDDING_URL=
CLAWMARK_EMBEDDING_MODEL=
CLAWMARK_EMBEDDING_DIM=1024

# OpenAI-compatible /v1/chat/completions endpoint for background fact extraction.
# Prefer a small fast model that doesn't share slots with your interactive chat model.
CLAWMARK_EXTRACT_URL=
CLAWMARK_EXTRACT_MODEL=

# Optional tuning:
#CLAWMARK_CONFIDENCE_THRESHOLD=0.8
#CLAWMARK_RECALL_LIMIT=6
#CLAWMARK_IDLE_HOURS=3
#CLAWMARK_RERANK_URL=
